## Web (Next.js) — set in the Railway web service
NEXT_PUBLIC_API_URL=https://your-server-service.up.railway.app

## Server (Elysia) — set in the Railway server service
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
DATABASE_URL=postgresql://postgres:password@host:port/railway
CORS_ORIGIN=https://your-web-service.up.railway.app
SESSION_COOKIE_NAME=reps_session
SESSION_COOKIE_SECURE=true
# PORT is auto-injected by Railway; the server reads process.env.PORT.
