# =============================================================================
# Reps env vars
# Paste the relevant section into the Variables tab of each Railway service.
# =============================================================================

# -----------------------------------------------------------------------------
# Server service (Elysia/Bun) — set in Railway → server → Variables
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Reference the linked Postgres service. Type the literal string with ${{ }};
# Railway resolves it at deploy time. Don't paste the raw connection URL.
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Comma-separated list of allowed web origins. Must match exactly (no trailing
# slash). Wildcards are supported: https://*.up.railway.app
CORS_ORIGIN=https://your-web-service.up.railway.app

# SESSION_COOKIE_SECURE defaults to true — Secure+SameSite=None cookies, the
# combo needed for cross-subdomain HTTPS deploys. Only set this to "false"
# for local dev (http://localhost rejects Secure cookies):
# SESSION_COOKIE_SECURE=false

# Optional cookie name override (defaults to reps_session).
# SESSION_COOKIE_NAME=reps_session

# Do NOT set PORT on Railway — the platform injects it. Setting a fixed value
# breaks the proxy.

# -----------------------------------------------------------------------------
# Web service (Next.js) — set in Railway → web → Variables
# -----------------------------------------------------------------------------
# The public URL of the server service. Must include https://.
NEXT_PUBLIC_API_URL=https://your-server-service.up.railway.app
