{
	"name": "server",
	"description": "Elysia backend API for XORS projects.",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"dev": "bun run --watch src/index.ts",
		"build": "echo 'No build step needed — Bun runs TypeScript directly'",
		"start": "bun run src/index.ts",
		"test": "bun test",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write --unsafe .",
		"format": "biome format .",
		"format:fix": "biome format --write .",
		"type-check": "tsc --pretty --noEmit"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.77.0",
		"@elysiajs/swagger": "^1.2.3",
		"elysia": "^1.3.2",
		"pdf-parse": "1.1.1",
		"postgres": "^3.4.9"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.11",
		"@types/bun": "latest",
		"typescript": "^5.9.3"
	}
}
