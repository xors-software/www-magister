{
	"name": "web",
	"description": "Reps — Anthropic Claude Code certification prep, scenario-based AI tutoring and mock exams.",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"dev": "next dev --port 3000",
		"turbo": "next dev --turbopack",
		"build": "next build",
		"build-icons": "svgr --out-dir app/components/icons/generated --icon --replace-attr-values '#fff=currentColor' --typescript icon-svg",
		"clean": "rm -rf node_modules .next",
		"type-check": "tsc --pretty --noEmit",
		"test": "vitest run --pool=forks",
		"test:watch": "vitest --pool=forks",
		"start": "next start",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write --unsafe .",
		"format": "biome format .",
		"format:fix": "biome format --write ."
	},
	"dependencies": {
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-slot": "^1.2.4",
		"@tanstack/react-query": "^5.90.16",
		"@types/katex": "^0.16.8",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"katex": "^0.16.28",
		"lodash": "^4.17.21",
		"next": "^16.1.1",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"react-markdown": "^10.1.0",
		"react-use": "^17.6.0",
		"remark-gfm": "^4.0.1",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.4.0",
		"zod": "^4.3.5"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.11",
		"@tailwindcss/postcss": "^4.1.18",
		"@svgr/cli": "^8.1.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.1",
		"@total-typescript/ts-reset": "^0.6.1",
		"@types/jest": "^30.0.0",
		"@types/lodash": "^4.17.23",
		"@types/node": "^25.0.6",
		"@types/react": "^19.2.8",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.2",
		"autoprefixer": "^10.4.23",
		"jsdom": "^27.4.0",
		"postcss": "^8.5.6",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vitest": "^4.0.16"
	}
}
